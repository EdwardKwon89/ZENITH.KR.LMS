#!/bin/bash
# ZENITH_LMS — Pre-commit Gate
# R-08: 회귀 테스트 통과 필수 (R-01 에이전트 태그는 commit-msg 훅에서 검증)
# R-17: ACTIVE_TASK 체계 준수 (구 R-TB TASK_BOARD 보호 → 폐기 2026-05-16)

set -e

# ── R-08: 회귀 테스트 결과 확인 ──────────────────────────────────
REGRESSION_FILE=".agent/LAST_REGRESSION_RESULT"

if [ -f "$REGRESSION_FILE" ]; then
  RESULT=$(cat "$REGRESSION_FILE" | tr -d '[:space:]')
  if [ "$RESULT" != "PASS" ]; then
    echo ""
    echo "❌ BLOCKED: 회귀 테스트 미통과 (R-08 위반)"
    echo "   마지막 결과: $RESULT"
    echo "   실행: rtk npm run test:regression"
    echo ""
    exit 1
  fi
fi

# ── R-17: ACTIVE_TASK 동기화 경고 ─────────────────────────────────
# Task 상세 파일 변경 시 ACTIVE_TASK.md도 함께 변경됐는지 확인
TASK_FILES=$(git diff --cached --name-only | grep "^\.agent/tasks/TASK-" || true)

if [ -n "$TASK_FILES" ]; then
  if ! git diff --cached --name-only | grep -q "^\.agent/ACTIVE_TASK\.md$"; then
    echo ""
    echo "⚠️  경고: Task 상세 파일 변경 시 ACTIVE_TASK.md 동기화 권장 (R-17)"
    echo "   변경된 Task 파일:"
    echo "$TASK_FILES" | sed 's/^/     /'
    echo "   ACTIVE_TASK.md 상태가 이미 최신이면 무시하십시오."
    echo ""
  fi
fi

echo "✅ Pre-commit 게이트 통과 — 커밋 진행"
exit 0
